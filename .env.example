# Environment Configuration for Hemera Academy
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# Application Configuration
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Database Configuration  
# =============================================================================
# Vercel Postgres (Production)
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Local Development Database (Alternative)
# DATABASE_URL="postgresql://username:password@localhost:5432/hemera"

# =============================================================================
# Clerk Authentication Configuration
# =============================================================================
# Get these from your Clerk Dashboard: https://dashboard.clerk.dev

# Required - Basic Clerk Configuration (set real values in your local .env.local)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY


# Optional - Custom URLs (defaults provided)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# =============================================================================
# Social Login Configuration (Optional)
# =============================================================================
# Configure these in your Clerk Dashboard under "Social Connections"
# No additional environment variables needed for Clerk social logins
# Clerk handles OAuth flow automatically

# Available providers to enable in Clerk Dashboard:
# - Google OAuth
# - GitHub OAuth  
# - Microsoft OAuth
# - Apple OAuth
# - Discord OAuth
# - Twitter/X OAuth

# =============================================================================
# Stripe Payment Configuration
# =============================================================================
# Get these from your Stripe Dashboard: https://dashboard.stripe.com

# Required - Stripe API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Required - Stripe Webhook Configuration
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional - Stripe Configuration
STRIPE_CURRENCY=USD

# =============================================================================
# Feature Flags (Optional)
# =============================================================================
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=true
NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION=true
NEXT_PUBLIC_ENABLE_TWO_FACTOR=false

# =============================================================================
# Analytics & Monitoring (Optional)
# =============================================================================
# NEXT_PUBLIC_GOOGLE_ANALYTICS=G-XXXXXXXXXX
# SENTRY_DSN=https://XXXXXXXXXX@sentry.io/XXXXXXXXXX

# Rollbar Configuration for Error Monitoring
# Rollbar tokens - keep these as placeholders in example files. Do NOT commit real tokens.
#
# `ROLLBAR_CLIENT_ACCESS_TOKEN` / `NEXT_PUBLIC_ROLLBAR_CLIENT_ACCESS_TOKEN`:
#   - Public-facing token used by client-side SDKs (POST_ITEM / client-side telemetry).
#   - Safe to expose as `NEXT_PUBLIC_...` in examples, but never include a real value in the repo.
#
# `ROLLBAR_SERVER_ACCESS_TOKEN`:
#   - Server-side token used for runtime error reporting and Rollbar server SDKs.
#   - Keeps write access to your Rollbar project; keep this secret and store in environment/secret store.
#
# `ROLLBAR_MCP_ACCESS_TOKEN` (optional naming for MCP/AI integrations):
#   - If you use a separate token for AI/MCP tools, store it separately (never in committed files).
ROLLBAR_SERVER_ACCESS_TOKEN=
ROLLBAR_CLIENT_ACCESS_TOKEN=
NEXT_PUBLIC_ROLLBAR_CLIENT_ACCESS_TOKEN=
ROLLBAR_ENABLED=true

# =============================================================================
# Service / Integration Environment Variables (placeholders)
# =============================================================================
# Hemera API URL (server-side): set this where Aither or other services call Hemera
HEMERA_API_URL=https://hemera.example.com

# Clerk (client-side vs server-side)
# - Client-side (public): NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# - Server-side (secret): CLERK_SECRET_KEY
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY

# Service-User placeholders (server-side only). Replace with secrets managed outside the repo.
# CLERK_SERVICE_USER_EMAIL: email of the Clerk service user (for reference)
# CLERK_SERVICE_USER_API_KEY or CLERK_SERVICE_USER_ID: server-side credential/identifier used by integrations
CLERK_SERVICE_USER_EMAIL=
CLERK_SERVICE_USER_API_KEY=

# Vercel Deployment Info (Auto-populated by Vercel)
# VERCEL_GIT_COMMIT_SHA=
# VERCEL_GIT_COMMIT_REF=
# VERCEL_URL=
# VERCEL_DEPLOYMENT_ID=
# VERCEL_REGION=