# Hemera Environment Variables Example
# Copy this file to .env.local and fill in your values

# =============================================================================
# DATABASE
# =============================================================================

# Local Docker PostgreSQL (npm run db:docker:start)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hemera?schema=hemera

# Alternative: Neon (for cloud/preview deployments)
# DATABASE_URL=postgres://USER:PASS@ep-xxxx-pooler.eu-central-1.aws.neon.tech/DBNAME?sslmode=require&schema=hemera

# =============================================================================
# CLERK AUTHENTICATION
# =============================================================================

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# MONITORING (optional for local dev)
# =============================================================================

# Rollbar error tracking
# Production/preview activate when valid tokens are present.
# Local development stays off by default and requires explicit opt-in.
# Use development-only Rollbar tokens here, never production tokens.
# Example local setup for the Rollbar development environment:
# ROLLBAR_HEMERA_SERVER_TOKEN=post_server_item_token_from_rollbar_dev_project
# NEXT_PUBLIC_ROLLBAR_HEMERA_CLIENT_TOKEN=post_client_item_token_from_rollbar_dev_project
# ROLLBAR_ENABLED=1
# NEXT_PUBLIC_ROLLBAR_ENABLED=1
# NEXT_PUBLIC_VERCEL_ENV=development
#
# Minimal server-only local setup:
# ROLLBAR_HEMERA_SERVER_TOKEN=
# ROLLBAR_ENABLED=1
#
# Optional browser telemetry in local development:
# NEXT_PUBLIC_ROLLBAR_HEMERA_CLIENT_TOKEN=
# NEXT_PUBLIC_ROLLBAR_ENABLED=1
# Optional: Vercel sets this automatically in hosted environments.
# NEXT_PUBLIC_VERCEL_ENV=development

# =============================================================================
# CONTEXT7 AI CONTEXT RETRIEVAL (optional)
# =============================================================================

# Context7 SDK for AI-powered context retrieval (opt-in via CONTEXT7_ENABLED=1)
# CONTEXT7_ENABLED=1
# CONTEXT7_API_KEY=

# =============================================================================
# UPSTASH REDIS RATE LIMITING (optional, requires package installation)
# =============================================================================

# Distributed rate limiting with Upstash Redis (opt-in via UPSTASH_ENABLED=1)
# Requires: npm install @upstash/redis @upstash/ratelimit
# UPSTASH_ENABLED=1
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# =============================================================================
# MUX VIDEO (optional)
# =============================================================================

# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=

# =============================================================================
# ROLLBAR MCP SERVER (read+write scope token for AI tools)
# =============================================================================

# ROLLBAR_ACCESS_TOKEN=
