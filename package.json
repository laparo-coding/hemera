{
  "name": "hemera",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "test-exclude": "^7.0.1"
  },
  "scripts": {
    "dev": "next dev -p 3000 & npx next-video sync -w",
    "build": "node scripts/verify-env.mjs && node scripts/deploy-migrations.mjs && next build --webpack",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "pretest": "prisma generate",
    "test": "npm run test:unit && npm run test:contracts && npm run test:integration",
    "test:unit": "vitest run tests/unit --environment jsdom",
    "test:unit:coverage": "vitest run tests/unit --environment jsdom --coverage",
    "test:contracts": "vitest run tests/contracts",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:functional": "playwright test --project=public --project=chromium-auth --project=auth-admin",
    "test:e2e:public": "playwright test --project=public",
    "test:e2e:auth-user": "playwright test --project=chromium-auth",
    "test:e2e:auth-admin": "playwright test --project=auth-admin",
    "test:e2e:performance": "playwright test --project=performance",
    "test:e2e:smoke": "playwright test --project=production-smoke",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:contracts && npm run test:e2e",
    "test:watch": "vitest",
    "test:prettier": "node tests/prettier-test-simple.js",
    "set-admin-role": "npx tsx scripts/set-admin-role.ts",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "format:staged": "biome format --write",
    "coverage:summary": "node scripts/coverage/report-summary.mjs",
    "coverage:check": "node scripts/coverage/assert-gates.mjs",
    "db:status": "dotenv -e .env.local -- npx prisma migrate status",
    "db:check-env": "dotenv -e .env.local -- npx tsx scripts/db-check-env.ts",
    "db:migrate": "npm run db:check-env && dotenv -e .env.local -- npx prisma migrate dev",
    "db:deploy": "dotenv -e .env.local -- npx prisma migrate deploy",
    "db:seed": "npm run db:check-env && dotenv -e .env.local -- npx tsx prisma/seed.ts",
    "db:seed:e2e-local": "dotenv -e .env.local -- npx tsx scripts/e2e-seed-local.ts",
    "db:reset": "echo '🚨 db:reset is DISABLED for safety. Use db:reset:force with ALLOW_DESTRUCTIVE_DB_OPS=true' && exit 1",
    "db:reset:force": "npm run db:check-env && dotenv -e .env.local -- npx prisma migrate reset",
    "db:list:courses": "dotenv -e .env.local -- node scripts/debug/list-courses.mjs",
    "db:restore:courses": "npm run db:check-env && node scripts/ops/restore-courses-from-backup.mjs",
    "db:docker:start": "docker compose up -d postgres && echo '✅ PostgreSQL started on localhost:5432'",
    "db:docker:stop": "docker compose stop postgres",
    "db:docker:reset": "docker compose down -v && docker compose up -d postgres && echo '✅ Database reset complete'",
    "db:docker:logs": "docker compose logs -f postgres",
    "e2e": "CI=1 NEXT_PUBLIC_DISABLE_CLERK=1 E2E_TEST=1 NEXT_PUBLIC_DISABLE_ROLLBAR=1 npm run build && CI=1 NEXT_PUBLIC_DISABLE_CLERK=1 E2E_TEST=1 NEXT_PUBLIC_DISABLE_ROLLBAR=1 PW_WEB_SERVER_COMMAND='npm run start' playwright test",
    "e2e:dev": "CI=1 NEXT_PUBLIC_DISABLE_CLERK=1 E2E_TEST=1 NEXT_PUBLIC_DISABLE_ROLLBAR=1 PW_WEB_SERVER_COMMAND='npm run dev' playwright test",
    "e2e:install": "playwright install chromium",
    "spellcheck": "cspell --config ./cspell.config.yaml --no-progress --no-summary --exclude 'cspell.config.*' lint 'app/**/*.{ts,tsx,js,jsx,md,mdx}' 'src/**/*.{ts,tsx,js,jsx,md,mdx}' 'docs/**/*.{md,mdx}'",
    "spellcheck:fix": "cspell --config ./cspell.config.yaml --no-progress --no-summary --wordsOnly --unique --exclude 'cspell.config.*' lint 'app/**/*.{ts,tsx,js,jsx,md,mdx}' 'src/**/*.{ts,tsx,js,jsx,md,mdx}' 'docs/**/*.{md,mdx}'",
    "stripe:key:check": "sh -c 'if [ -f .env.development.local ]; then dotenv -e .env.development.local -- node scripts/check-stripe-key.mjs; elif [ -f .env.local ]; then dotenv -e .env.local -- node scripts/check-stripe-key.mjs; else node scripts/check-stripe-key.mjs; fi'"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched",
      "cspell --config ./cspell.config.yaml --no-progress --no-summary --no-must-find-files --exclude 'lib/generated/**'"
    ],
    "*.json": [
      "biome format --write"
    ],
    "*.{md,mdx}": [
      "cspell --config ./cspell.config.yaml --no-progress --no-summary --no-must-find-files"
    ]
  },
  "dependencies": {
    "@clerk/localizations": "^4.5.3",
    "@clerk/nextjs": "^7.2.5",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@floating-ui/dom": "^1.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "7.3.10",
    "@mui/x-date-pickers": "9.0.2",
    "@mux/mux-player-react": "^3.11.8",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "~7.8.0",
    "@rollbar/react": "^1.0.0",
    "@stripe/react-stripe-js": "6.2.0",
    "@stripe/stripe-js": "9.3.0",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.19.0",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@upstash/context7-sdk": "^0.3.0",
    "@vercel/blob": "^2.3.3",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "loops": "^6.3.0",
    "next": "^16.2.4",
    "next-video": "^2.7.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-leaflet": "^5.0.0",
    "rollbar": "^3.1.0",
    "sharp": "^0.34.5",
    "stripe": "^22.0.2",
    "uuid": "^14.0.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "^2.4.12",
    "@cspell/dict-de-de": "^4.1.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@stoplight/spectral-cli": "^6.15.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "cross-env": "10.1.0",
    "cspell": "^9.8.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "husky": "^9.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.5",
    "openapi-to-postmanv2": "^6.0.1",
    "playwright": "^1.56.1",
    "prisma": "~7.8.0",
    "testcontainers": "^11.7.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^7.1.12",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "webpack": "^5.106.2"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts"
  }
}
