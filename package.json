{
  "name": "hemera",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "overrides": {
    "test-exclude": "^7.0.1"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "node scripts/verify-env.mjs && next build --webpack",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "lint:ci": "eslint --cache --max-warnings=250 .",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "pretest": "prisma generate",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:contracts": "jest tests/contracts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:contracts && npm run test:e2e",
    "test:watch": "jest --watch",
    "test:prettier": "node tests/prettier-test-simple.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:staged": "prettier --write",
    "db:status": "dotenv -e .env.local -- npx prisma migrate status",
    "db:migrate": "dotenv -e .env.local -- npx prisma migrate dev",
    "db:deploy": "dotenv -e .env.local -- npx prisma migrate deploy",
    "db:seed": "dotenv -e .env.local -- node --loader ts-node/esm prisma/seed.ts",
    "db:list:courses": "dotenv -e .env.local -- node scripts/debug/list-courses.mjs",
    "e2e": "CI=1 NEXT_PUBLIC_DISABLE_CLERK=1 E2E_TEST=true NEXT_PUBLIC_ROLLBAR_ENABLED=0 npm run build && CI=1 NEXT_PUBLIC_DISABLE_CLERK=1 E2E_TEST=true NEXT_PUBLIC_ROLLBAR_ENABLED=0 PW_WEB_SERVER_COMMAND='npm run start' playwright test",
    "e2e:dev": "CI=1 NEXT_PUBLIC_DISABLE_CLERK=1 E2E_TEST=true NEXT_PUBLIC_ROLLBAR_ENABLED=0 PW_WEB_SERVER_COMMAND='npm run dev' playwright test",
    "e2e:install": "playwright install chromium",
    "spellcheck": "cspell --config ./cspell.config.yaml --no-progress --no-summary --exclude 'cspell.config.*' lint 'app/**/*.{ts,tsx,js,jsx,md,mdx}' 'src/**/*.{ts,tsx,js,jsx,md,mdx}' 'docs/**/*.{md,mdx}'",
    "spellcheck:fix": "cspell --config ./cspell.config.yaml --no-progress --no-summary --wordsOnly --unique --exclude 'cspell.config.*' lint 'app/**/*.{ts,tsx,js,jsx,md,mdx}' 'src/**/*.{ts,tsx,js,jsx,md,mdx}' 'docs/**/*.{md,mdx}'",
    "stripe:key:check": "sh -c 'if [ -f .env.development.local ]; then dotenv -e .env.development.local -- node scripts/check-stripe-key.mjs; elif [ -f .env.local ]; then dotenv -e .env.local -- node scripts/check-stripe-key.mjs; else node scripts/check-stripe-key.mjs; fi'"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "cspell --config ./cspell.config.yaml --no-progress --no-summary --no-must-find-files --exclude 'lib/generated/**'",
      "eslint --max-warnings=350 --cache --fix"
    ],
    "*.{json,yaml,yml}": [
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "prettier --write",
      "cspell --config ./cspell.config.yaml --no-progress --no-summary --no-must-find-files"
    ]
  },
  "dependencies": {
    "@clerk/localizations": "^3.29.1",
    "@clerk/nextjs": "^6.36.0",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.4",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@rollbar/react": "^1.0.0",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.5.3",
    "date-fns": "^4.1.0",
    "next": "^16.0.7",
    "pg": "^8.16.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rollbar": "^2.26.4",
    "stripe": "^20.0.0",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@cspell/dict-de-de": "^4.1.2",
    "@eslint/js": "^9.17.0",
    "@jest/globals": "^30.2.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.0.7",
    "@playwright/test": "^1.57.0",
    "@testcontainers/postgresql": "^11.9.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/visitor-keys": "^8.48.1",
    "cspell": "^9.4.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.7",
    "globals": "^16.5.0",
    "husky": "^9.0.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.56.1",
    "prettier": "^3.7.4",
    "prisma": "^7.0.0",
    "testcontainers": "^11.7.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts"
  }
}
